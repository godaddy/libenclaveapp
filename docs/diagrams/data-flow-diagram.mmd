flowchart TB
    %% External entity
    app(["fa:fa-cube Consuming Application\n(gocode-dev, sshenc, awsenc, npmenc, sso-jwt)"]):::external

    subgraph libapi["libenclaveapp API Boundary"]
        direction TB

        subgraph coremod["Core Modules"]
            direction LR
            appstorage["enclaveapp-app-storage\n(backend selection, policy)"]:::coreprocess
            core["enclaveapp-core\n(traits, metadata, crypto)"]:::coreprocess
            harden["process::harden_process()\n(PR_SET_DUMPABLE, no cores)"]:::coreprocess
        end

        subgraph optional["Optional Layers"]
            direction LR
            adapter["enclaveapp-app-adapter\n(secret delivery)"]:::optprocess
            cache["enclaveapp-cache\n(envelope, rollback counter)"]:::optprocess
        end

        subgraph backends["Platform Backends (compile-time selected)"]
            direction LR
            apple["enclaveapp-apple\n(Secure Enclave + Keychain)"]:::backend
            windows["enclaveapp-windows\n(TPM / CNG)"]:::backend
            webauthn["enclaveapp-windows-webauthn\n(Security Key)"]:::backend
            linuxtpm["enclaveapp-linux-tpm\n(TPM2)"]:::backend
            keyring["enclaveapp-keyring\n(Secret Service / software)"]:::weakbackend
        end
    end

    subgraph hwsecure["Hardware Secure Element"]
        direction LR
        se["Apple Secure Enclave"]:::hw
        tpm["TPM 2.0 chip"]:::hw
        fido["FIDO2 / Security Key"]:::hw
    end

    subgraph wslbridge["WSL Bridge Path"]
        direction LR
        wslclient["enclaveapp-wsl\n(bridge client)"]:::bridge
        wslserver["enclaveapp-tpm-bridge\n(Windows host process)"]:::bridge
    end

    subgraph disk["On-Disk Artifacts (user-writable, 0600)"]
        direction LR
        ciphertext[("Ciphertext\n.enc")]:::securedisk
        meta[("Key Metadata\n.meta")]:::neutraldisk
        handles[("Key Handles\n.handle")]:::neutraldisk
        pubkeys[("Public Keys\n.pub")]:::neutraldisk
        hmac[("HMAC Tags\n(integrity)")]:::securedisk
        counter[("Rollback Counter\n(monotonic)")]:::securedisk
    end

    %% Flows
    app -->|"generate / sign / encrypt / decrypt"| appstorage
    appstorage -->|"validate labels + policy"| core
    appstorage -->|"optional delivery"| adapter
    appstorage -->|"optional cache header binding"| cache
    core --> harden

    appstorage -->|"platform operation"| apple
    appstorage -->|"platform operation"| windows
    appstorage -->|"platform operation"| webauthn
    appstorage -->|"platform operation"| linuxtpm
    appstorage -->|"software fallback"| keyring

    apple -->|"ECDH / Sign"| se
    windows -->|"ECDH / Sign"| tpm
    webauthn -->|"assertion"| fido

    appstorage -->|"WSL TPM request"| wslclient
    wslclient -->|"bounded JSON-RPC\nover stdio"| wslserver
    wslserver -->|"Windows TPM op"| tpm

    appstorage -->|"read/write"| ciphertext
    core -->|"read/write"| meta
    core -->|"read/write"| handles
    core -->|"read/write"| pubkeys
    core -->|"verify / write"| hmac
    cache -->|"read/write"| counter

    se -->|"signature / ECDH result"| apple
    tpm -->|"signature / ECDH result"| windows

